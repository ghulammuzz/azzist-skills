# azzist secrets — DO NOT COMMIT. Copy to azzist.local.yaml and fill in.
# azzist.local.yaml is gitignored. This .example file is safe to commit.

cloudflare:
  api_token: "CF_API_TOKEN_WITH_DNS_EDIT_ON_THIS_ZONE"  # scope: Zone.DNS Edit on the one zone only
  zone_id: "CF_ZONE_ID"

# How the SERVER authenticates to pull the repo (only for deploy.transfer: git).
git:
  auth: deploy_key      # deploy_key | ssh_agent | token
                        #   deploy_key: read-only key already installed on the server (recommended)
                        #   ssh_agent:  forward your local ssh-agent (ssh -A) at deploy time
                        #   token:      HTTPS personal access token (read-only)
  # token: "GH_READ_ONLY_PAT"   # only when auth: token

servers:
  prod:
    host: 1.2.3.4
    ssh_user: root

    # Choose ONE auth mode:
    auth: ssh_config            # ssh_config | key | password

    # auth: ssh_config  -> uses your ~/.ssh/config Host alias (recommended)
    ssh_alias: myserver

    # auth: key -> private key file
    # key_path: ~/.ssh/id_ed25519

    # auth: password -> requires sshpass installed locally (discouraged; prefer key/ssh_config)
    # password: "..."
