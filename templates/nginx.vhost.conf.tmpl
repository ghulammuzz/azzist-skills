# azzist-managed vhost — file: /etc/nginx/conf.d/azzist___NAME__.conf
# Placeholders __DOMAIN__, __PORT__, __NAME__ are replaced at deploy time.
# This file is the ONLY thing azzist writes to nginx. Existing config is never touched.

server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__;

    location / {
        proxy_pass http://127.0.0.1:__PORT__;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # websocket support
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
